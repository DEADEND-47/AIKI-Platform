# LLM — groq.com/console
GROQ_API_KEY=

# Embeddings — jina.ai
JINA_API_KEY=

# Vector Store — cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=industrial_docs

# Knowledge Graph — console.neo4j.io AuraDB Free
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# PostgreSQL — Render internal DB URL or local postgres/sqlite (leave empty for SQLite fallback)
DATABASE_URL=

# App config
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
ANONYMIZED_TELEMETRY=false
